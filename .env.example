# ── On-Prem LLM Inference (default / production) ──────────────────────
# Development (Ollama, CPU):
INFERENCE_URL=http://localhost:11434/v1
MODEL_NAME=minicpm-v:latest

# Production (vLLM, GPU) — swap these two lines for prod:
# INFERENCE_URL=http://inference-server:8080/v1
# MODEL_NAME=qwen2-vl-7b-instruct

# ── Provider selection ────────────────────────────────────────────────
# LLM_PROVIDER=ollama   ← default; uses INFERENCE_URL above (production-safe)
# LLM_PROVIDER=claude   ← demo/testing only; requires ANTHROPIC_API_KEY below
LLM_PROVIDER=ollama
LLM_TIMEOUT_S=120.0
LLM_MAX_RETRIES=2

# ── Claude API (demo/testing only — NEVER use in production) ──────────
# Install the demo extras first: poetry install --with demo
# Then set your key here (never commit this file with a real key):
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# ── Application URLs ──────────────────────────────────────────────────
# Simulation (local dev):
LD_BASE_URL=http://localhost:8000
IIM_BASE_URL=http://localhost:8001
RDWEB_URL=http://localhost:8000/rdweb

# Production (App VM):
# LD_BASE_URL=http://app-vm-ip:8000
# IIM_BASE_URL=http://app-vm-ip:8001
# RDWEB_URL=https://app-vm-ip/RDWeb

# ── RDP ───────────────────────────────────────────────────────────────
RDP_HOST=app-vm-ip
RDP_USERNAME=automation_user
RDP_PASSWORD=REPLACE_WITH_VAULT_SECRET

# ── Simulation credentials (legacy/simulation defaults) ────────────────
# These match legacy/simulation/data/users.json. Used by legacy code AND by
# the new framework when LD_BASE_URL points at the local sim.
SIM_USERNAME=plp\sonawane001
SIM_PASSWORD=Welcome@123
SSO_USERNAME=vsonawane001
SSO_PASSWORD=Welcome@123

# ── Credentials (use Vault in production — never hardcode) ────────────
# RDWEB_USERNAME / RDWEB_PASSWORD are what the new framework reads via
# config/settings.py. For local sim, leave them mirroring SIM_* above.
RDWEB_USERNAME=plp\sonawane001
RDWEB_PASSWORD=Welcome@123

# ── Agent ─────────────────────────────────────────────────────────────
AGENT_ID=agent_01
MAX_LOOP_STEPS=50
CONFIDENCE_THRESHOLD=0.75
FINANCIAL_CONFIDENCE_THRESHOLD=0.90
HITL_TIMEOUT_MINUTES=30
HITL_SERVER_PORT=8080

# ── Mode flags ────────────────────────────────────────────────────────
USE_SIMULATION=true          # true=simulation sites, false=real apps
HEADLESS=false               # true=no browser UI (CI/server), false=visible
DEMO_SLOWMO=0                # ms delay between Playwright actions (0=full speed)

# ── Paths ─────────────────────────────────────────────────────────────
DB_DIR=./data/db
CHROMA_PATH=./data/chroma
SCREENSHOT_DIR=./screenshots
AUDIT_LOG_DIR=./logs/audit
DOWNLOAD_DIR=./downloads

ANONYMIZED_TELEMETRY=False
CHROMA_TELEMETRY_IMPL=NoneTelemetryClient